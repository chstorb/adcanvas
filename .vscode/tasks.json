{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-js",
      "type": "shell",
      "command": "terser src/js/adcanvas.js --compress --mangle --output dist/adcanvas.min.js --source-map \"url=adcanvas.min.js.map\""
    },
    {
      "label": "build-css",
      "type": "shell",
      "command": "cleancss --source-map -o dist/adcanvas.min.css src/css/adcanvas.css"
    },
    {
      "label": "build-all",
      "dependsOn": ["build-js", "build-css"],
      "group": "build"
    }
  ]
}
